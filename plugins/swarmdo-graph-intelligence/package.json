{
  "name": "swarmdo-graph-intelligence",
  "version": "0.1.0-alpha.1",
  "description": "Swarmdo Graph Intelligence Engine \u2014 real-time relationship intelligence with complexity-aware execution. Single-entry personalized PageRank, streaming delta updates, witness-signed reasoning artifacts over Swarmdo's substrate graphs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./mcp-tools": "./dist/mcp-tools/index.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "bench": "node scripts/benchmark-substrate.mjs"
  },
  "dependencies": {
    "sublinear-time-solver": "^1.7.0",
    "zod": "^3.22.4"
  },
