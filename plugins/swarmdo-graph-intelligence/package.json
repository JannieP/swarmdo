    "sublinear",
    "complexity-aware",
    "personalized-pagerank",
    "agent-substrate",
    "mcp",
    "swarmdo"
  ],
  "author": "ruvnet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JannieP/swarmdo.git",
