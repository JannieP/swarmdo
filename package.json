{
  "name": "swarmdo",
  "version": "1.24.1",
  "description": "Swarmdo - Enterprise AI agent orchestration for Claude Code. Deploy 60+ specialized agents in coordinated swarms with self-learning, fault-tolerant consensus, vector memory, and MCP integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "swarmdo": "./bin/cli.js"
  },
  "homepage": "https://swarmdo.com",
  "bugs": {
    "url": "https://github.com/SwarmDo/swarmdo/issues",
    "email": "maintainers@swarmdo.com"
  },
  "files": [
    "bin/**",
    "v3/@swarmdo/*/package.json",
    "v3/@swarmdo/*/bin/**",
    "v3/@swarmdo/*/dist/**/*.js",
    "v3/@swarmdo/*/dist/**/*.d.ts",
    "v3/@swarmdo/*/dist/**/*.cjs",
    "v3/@swarmdo/*/dist/**/*.json",
    "v3/@swarmdo/*/dist/**/*.wasm",
    "v3/@swarmdo/cli/scripts/**",
    "v3/@swarmdo/cli/.claude/**",
    "v3/@swarmdo/cli/plugins/**",
    "v3/@swarmvector/*/package.json",
    "v3/@swarmvector/*/*.cjs",
    "v3/@swarmvector/*/*.mjs",
    "v3/@swarmvector/*/*.js",
    "v3/@swarmvector/*/*.d.ts",
    "v3/@swarmvector/*/*.wasm",
    "v3/@swarmvector/*/*.node",
    "v3/@swarmvector/*/dist/**",
    "v3/@swarmvector/*/pkg/**",
    "v3/@swarmvector/*/platforms/**",
    "v3/@swarmvector/*/bin/**",
    "v3/@swarmvector/*/scripts/**",
    "v3/vendor/*/package.json",
    "v3/vendor/*/*.cjs",
    "v3/vendor/*/*.js",
    "v3/vendor/*/*.mjs",
    "v3/vendor/*/*.d.ts",
    "v3/vendor/*/*.wasm",
    "v3/vendor/*/dist/**",
    "v3/vendor/*/scripts/**",
    "v3/vendor/*/bin/**",
    "!v3/@swarmdo/*/dist/**/*.map",
    "!v3/@swarmvector/*/dist/**/*.map",
    "!v3/vendor/*/dist/**/*.map",
    "!v3/@swarmvector/**/test/**",
    "!v3/vendor/**/test/**",
    "!v3/@swarmdo/*/.claude/**/*.db",
    ".claude-plugin/**",
    ".claude/**",
    "!.claude/**/*.db",
    "!.claude/**/*.map",
    "README.md",
    "LICENSE",
    "!.claude/scheduled_tasks.lock",
    "!.claude/**/__pycache__/**"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:ts": "cd v3/@swarmdo/cli && npm run build || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:security": "vitest run v3/__tests__/security/",
    "lint": "cd v3/@swarmdo/cli && npm run lint || true",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "v3:domains": "npm run build:domains",
    "v3:swarm": "npm run start:swarm",
    "v3:security": "npm run security:audit && npm run security:test"
  },
  "dependencies": {
    "@noble/ed25519": "2.3.0",
    "@swarmdo/cli": "file:v3/@swarmdo/cli",
    "@swarmdo/cli-core": "file:v3/@swarmdo/cli-core",
    "@swarmdo/guidance": "file:v3/@swarmdo/guidance",
    "@swarmdo/hooks": "file:v3/@swarmdo/hooks",
    "@swarmdo/mcp": "file:v3/@swarmdo/mcp",
    "@swarmdo/memory": "file:v3/@swarmdo/memory",
    "@swarmdo/neural": "file:v3/@swarmdo/neural",
    "@swarmdo/security": "file:v3/@swarmdo/security",
    "@swarmdo/shared": "file:v3/@swarmdo/shared",
    "@swarmvector/rabitq-wasm": "file:v3/@swarmvector/rabitq-wasm",
    "agentic-flow": "file:v3/vendor/agentic-flow",
    "pg": "8.22.0",
    "swarmvector": "file:v3/vendor/swarmvector",
    "swarmvector-attention-wasm": "file:v3/vendor/swarmvector-attention-wasm",
    "swarmvector-graph-transformer-wasm": "file:v3/vendor/swarmvector-graph-transformer-wasm",
    "swarmvector-onnx-embeddings-wasm": "file:v3/vendor/swarmvector-onnx-embeddings-wasm",
    "semver": "7.7.3",
    "zod": "3.25.76",
    "swarmdo-swarm": "file:v3/vendor/swarmdo-swarm"
  },
  "optionalDependencies": {
    "@swarmdo/aidefence": "file:v3/@swarmdo/aidefence",
    "@swarmdo/codex": "file:v3/@swarmdo/codex",
    "@swarmdo/embeddings": "file:v3/@swarmdo/embeddings",
    "@swarmvector/attention": "file:v3/@swarmvector/attention",
    "@swarmvector/core": "file:v3/@swarmvector/core",
    "@swarmvector/router": "file:v3/@swarmvector/router",
    "@swarmvector/rvf-node": "file:v3/@swarmvector/rvf-node",
    "@swarmvector/sona": "file:v3/@swarmvector/sona",
    "agentdb": "file:v3/vendor/agentdb"
  },
  "overrides": {
    "swarmvector": "file:v3/vendor/swarmvector",
    "better-sqlite3": ">=12.8.0",
    "hono": ">=4.11.4",
    "@swarmvector/rvf-wasm": "0.1.5",
    "@hono/node-server": ">=1.19.10",
    "flatted": ">=3.4.0",
    "tar": ">=7.5.11",
    "picomatch": ">=4.0.3",
    "path-to-regexp": ">=8.2.1",
    "undici": ">=7.18.0",
    "minimatch": ">=10.0.0",
    "@isaacs/brace-expansion": ">=5.0.1",
    "cacache": ">=20.0.0",
    "make-fetch-happen": ">=15.0.0",
    "express-rate-limit": ">=8.4.1",
    "express": ">=4.22.2",
    "qs": ">=6.15.2",
    "protobufjs": ">=8.2.0",
    "uuid": ">=14.0.0",
    "@opentelemetry/core": "1.25.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/sdk-trace-base": "1.25.1",
    "@opentelemetry/sdk-node": ">=0.218.0",
    "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
    "@opentelemetry/exporter-prometheus": ">=0.217.0",
    "axios": ">=1.13.2",
    "fast-uri": ">=3.1.0",
    "vite": ">=6.4.6",
    "ws": ">=8.18.4"
  },
  "devDependencies": {
    "@openai/codex": "^0.98.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SwarmDo/swarmdo.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "ai-agents",
    "multi-agent",
    "agent-orchestration",
    "swarm-intelligence",
    "swarm",
    "mcp",
    "model-context-protocol",
    "llm",
    "large-language-model",
    "gpt",
    "chatgpt",
    "automation",
    "workflow",
    "orchestration",
    "cli",
    "developer-tools",
    "devtools",
    "coding-assistant",
    "code-generation",
    "enterprise",
    "vector-database",
    "embeddings",
    "machine-learning",
    "neural-network",
    "hive-mind",
    "distributed-systems",
    "consensus",
    "self-learning"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
