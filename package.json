{
  "name": "rufflo",
  "version": "1.1.0",
  "description": "Rufflo - Enterprise AI agent orchestration for Claude Code. Deploy 60+ specialized agents in coordinated swarms with self-learning, fault-tolerant consensus, vector memory, and MCP integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "rufflo": "./bin/cli.js"
  },
  "homepage": "https://github.com/ruvnet/claude-flow#readme",
  "bugs": {
    "url": "https://github.com/ruvnet/claude-flow/issues",
    "email": "support@ruv.io"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ruvnet"
  },
  "files": [
    "bin/**",
    "v3/@rufflo/*/package.json",
    "v3/@rufflo/*/bin/**",
    "v3/@rufflo/*/dist/**/*.js",
    "v3/@rufflo/*/dist/**/*.d.ts",
    "v3/@rufflo/*/dist/**/*.cjs",
    "v3/@rufflo/*/dist/**/*.json",
    "v3/@rufflo/*/dist/**/*.wasm",
    "v3/@rufflo/cli/scripts/**",
    "v3/@rufflo/cli/.claude/**",
    "v3/@rufflo/cli/plugins/**",
    "v3/@rufvector/*/package.json",
    "v3/@rufvector/*/*.cjs",
    "v3/@rufvector/*/*.mjs",
    "v3/@rufvector/*/*.js",
    "v3/@rufvector/*/*.d.ts",
    "v3/@rufvector/*/*.wasm",
    "v3/@rufvector/*/*.node",
    "v3/@rufvector/*/dist/**",
    "v3/@rufvector/*/pkg/**",
    "v3/@rufvector/*/platforms/**",
    "v3/@rufvector/*/bin/**",
    "v3/@rufvector/*/scripts/**",
    "v3/vendor/*/package.json",
    "v3/vendor/*/*.cjs",
    "v3/vendor/*/*.js",
    "v3/vendor/*/*.mjs",
    "v3/vendor/*/*.d.ts",
    "v3/vendor/*/dist/**",
    "v3/vendor/*/scripts/**",
    "v3/vendor/*/bin/**",
    "!v3/@rufflo/*/dist/**/*.map",
    "!v3/@rufvector/*/dist/**/*.map",
    "!v3/vendor/*/dist/**/*.map",
    "!v3/@rufvector/**/test/**",
    "!v3/vendor/**/test/**",
    "!v3/@rufflo/*/.claude/**/*.db",
    ".claude-plugin/**",
    ".claude/**",
    "!.claude/**/*.db",
    "!.claude/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:ts": "cd v3/@rufflo/cli && npm run build || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:security": "vitest run v3/__tests__/security/",
    "lint": "cd v3/@rufflo/cli && npm run lint || true",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "v3:domains": "npm run build:domains",
    "v3:swarm": "npm run start:swarm",
    "v3:security": "npm run security:audit && npm run security:test"
  },
  "dependencies": {
    "@rufflo/cli": "file:v3/@rufflo/cli",
    "@rufflo/cli-core": "file:v3/@rufflo/cli-core",
    "@rufflo/mcp": "file:v3/@rufflo/mcp",
    "@rufflo/neural": "file:v3/@rufflo/neural",
    "@rufflo/shared": "file:v3/@rufflo/shared",
    "@rufflo/memory": "file:v3/@rufflo/memory",
    "@rufflo/security": "file:v3/@rufflo/security",
    "@rufflo/hooks": "file:v3/@rufflo/hooks",
    "@rufflo/guidance": "file:v3/@rufflo/guidance",
    "@noble/ed25519": "2.3.0",
    "semver": "7.7.3",
    "zod": "3.25.76",
    "@rufvector/rabitq-wasm": "file:v3/@rufvector/rabitq-wasm"
  },
  "optionalDependencies": {
    "@rufflo/aidefence": "file:v3/@rufflo/aidefence",
    "@rufflo/codex": "file:v3/@rufflo/codex",
    "@rufflo/embeddings": "file:v3/@rufflo/embeddings",
    "@rufvector/attention": "file:v3/@rufvector/attention",
    "@rufvector/core": "file:v3/@rufvector/core",
    "@rufvector/router": "file:v3/@rufvector/router",
    "@rufvector/rvf-node": "file:v3/@rufvector/rvf-node",
    "@rufvector/sona": "file:v3/@rufvector/sona",
    "agentdb": "file:v3/vendor/agentdb",
    "agentic-flow": "file:v3/vendor/agentic-flow"
  },
  "overrides": {
    "rufvector": "file:v3/vendor/rufvector",
    "better-sqlite3": ">=12.8.0",
    "hono": ">=4.11.4",
    "@rufvector/rvf-wasm": "0.1.5",
    "@hono/node-server": ">=1.19.10",
    "flatted": ">=3.4.0",
    "tar": ">=7.5.11",
    "picomatch": ">=4.0.3",
    "path-to-regexp": ">=8.2.1",
    "undici": ">=7.18.0",
    "minimatch": ">=10.0.0",
    "@isaacs/brace-expansion": ">=5.0.1",
    "cacache": ">=20.0.0",
    "make-fetch-happen": ">=15.0.0",
    "express-rate-limit": ">=8.4.1",
    "express": ">=4.22.2",
    "qs": ">=6.15.2",
    "protobufjs": ">=8.2.0",
    "uuid": ">=14.0.0",
    "@opentelemetry/core": "1.25.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/sdk-trace-base": "1.25.1",
    "@opentelemetry/sdk-node": ">=0.218.0",
    "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
    "@opentelemetry/exporter-prometheus": ">=0.217.0",
    "axios": ">=1.13.2",
    "fast-uri": ">=3.1.0",
    "vite": ">=6.4.6",
    "ws": ">=8.18.4"
  },
  "devDependencies": {
    "@openai/codex": "^0.98.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/claude-flow.git"
  },
  "keywords": [
    "ruvflow",
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "ai-agents",
    "multi-agent",
    "agent-orchestration",
    "swarm-intelligence",
    "swarm",
