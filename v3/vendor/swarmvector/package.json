{
  "name": "swarmvector",
  "version": "0.2.33",
  "description": "Self-learning vector database for Node.js \u2014 hybrid search, Graph RAG, FlashAttention-3, HNSW, 50+ attention mechanisms",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swarmvector": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/core/onnx','dist/core/onnx',{recursive:true})\"",
    "verify-dist": "node scripts/verify-dist.js",
    "prepack": "npm run build && npm run verify-dist",
    "prepublishOnly": "npm run build && npm run verify-dist",
    "test": "node test/integration.js && node test/cli-commands.js && node test/db-workflow.js && node test/sigterm-cleanup.js && node test/mcp-policy.js && node test/startup-budget.js"
  },
  "keywords": [
    "vector",
    "database",
    "vector-database",
    "vector-search",
    "similarity-search",
    "semantic-search",
    "embeddings",
    "hnsw",
    "ann",
    "ai",
    "machine-learning",
    "rag",
    "rust",
    "wasm",
    "native",
    "ruf",
    "swarmvector",
    "attention",
    "transformer",
    "flash-attention",
    "hyperbolic",
    "sona",
    "lora",
    "ewc",
    "adaptive-learning",
    "continual-learning",
    "onnx",
    "semantic-embeddings",
    "minilm",
    "brain",
    "shared-intelligence",
    "mcp",
    "edge-computing",
    "graph-rag",
    "hnsw",
    "hybrid-search",
    "colbert",
    "turboquant",
    "mamba",
    "pi-brain",
    "identity",
    "pi-key",
    "distributed-compute"
  ],
  "author": "swarmdo.com Team <maintainers@swarmdo.com> (https://swarmdo.com)",
  "homepage": "https://swarmdo.com",
  "bugs": {
    "url": "the upstream project (see NOTICE)"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "the upstream project (see NOTICE)",
    "directory": "npm/packages/swarmvector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@swarmvector/attention": "file:../../@swarmvector/attention",
    "@swarmvector/core": "file:../../@swarmvector/core",
    "@swarmvector/gnn": "file:../../@swarmvector/gnn",
    "@swarmvector/sona": "file:../../@swarmvector/sona",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "js-beautify": "^1.15.4",
    "ora": "^5.4.1"
  },
  "optionalDependencies": {
    "@swarmvector/rvf": "file:../../@swarmvector/rvf",
    "@swarmvector/tiny-dancer": "file:../../@swarmvector/tiny-dancer"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.9.3"
  },
  "files": [
    "bin/",
    "dist/",
    "src/decompiler/",
    "src/optimizer/",
    "wasm/",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@swarmvector/diskann": "file:../../@swarmvector/diskann",
    "@swarmvector/pi-brain": ">=0.1.0",
    "@swarmvector/router": "file:../../@swarmvector/router",
    "@swarmvector/swarmllm": "file:../../@swarmvector/swarmllm"
  },
  "peerDependenciesMeta": {
    "@swarmvector/pi-brain": {
      "optional": true
    },
    "@swarmvector/swarmllm": {
      "optional": true
    },
    "@swarmvector/router": {
      "optional": true
    },
    "@swarmvector/diskann": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
